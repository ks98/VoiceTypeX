{
  "$schema": "https://schema.tauri.app/config/2.0.0-rc",
  "productName": "VoiceTypeX",
  "version": "0.1.0",
  "identifier": "de.kevin-stenzel.voicetypex",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": "node ../scripts/bundle-libs.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceTypeX",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "overlay",
        "title": "VoiceTypeX Live",
        "url": "index.html?window=overlay",
        "width": 520,
        "height": 96,
        "minWidth": 320,
        "minHeight": 64,
        "x": 24,
        "y": 24,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "menu",
        "title": "VoiceTypeX Menü",
        "url": "index.html?window=menu",
        "width": 480,
        "height": 360,
        "minWidth": 320,
        "minHeight": 120,
        "x": 24,
        "y": 24,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Diktiere — VoiceTypeX schreibt es.",
    "longDescription": "VoiceTypeX ist ein Diktier-Tool, das Audio per Hotkey aufnimmt, lokal oder via Cloud transkribiert und den Text an der aktuellen Cursor-Position einfuegt. Konfigurierbare Modi steuern Transkription, LLM-Nachbearbeitung und Einfuege-Methode. BYOK-Cloud (xAI, OpenAI, Anthropic, Groq, Deepgram); lokal via whisper.cpp und Ollama.",
    "resources": [
      "../assets/cue_start.wav",
      "../assets/cue_stop.wav",
      "resources/lib/*"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libvulkan1",
          "mesa-vulkan-drivers",
          "libasound2",
          "libxdo3"
        ]
      },
      "rpm": {
        "depends": [
          "vulkan-loader",
          "mesa-vulkan-drivers",
          "alsa-lib",
          "libxdo"
        ]
      }
    }
  }
}
