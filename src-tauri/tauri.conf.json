{
  "$schema": "https://schema.tauri.app/config/2.0.0-rc",
  "productName": "VoiceTypeX",
  "identifier": "de.kevin-stenzel.voicetypex",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": "node scripts/bundle-libs.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceTypeX",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "VoiceTypeX Live",
        "url": "index.html?window=overlay",
        "width": 520,
        "height": 96,
        "minWidth": 320,
        "minHeight": 64,
        "center": true,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "menu",
        "title": "VoiceTypeX Menu",
        "url": "index.html?window=menu",
        "width": 480,
        "height": 360,
        "minWidth": 320,
        "minHeight": 120,
        "center": true,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://api.anthropic.com https://api.openai.com https://api.x.ai https://api.groq.com https://api.deepgram.com https://huggingface.co https://*.huggingface.co"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Dictate — VoiceTypeX writes it.",
    "longDescription": "VoiceTypeX is a dictation tool that records audio via a hotkey, transcribes it locally or via the cloud, and inserts the text at the current cursor position. Configurable modes control transcription, LLM postprocessing, and the insertion method. BYOK cloud (xAI, OpenAI, Anthropic, Groq, Deepgram); local via whisper.cpp and Ollama.",
    "resources": [
      "resources/lib/*"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libvulkan1",
          "mesa-vulkan-drivers",
          "libasound2",
          "libxdo3"
        ]
      },
      "rpm": {
        "depends": [
          "vulkan-loader",
          "mesa-vulkan-drivers",
          "alsa-lib",
          "libxdo"
        ]
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCMTVDRjEwRENBNUVCClJXVHJwZHdRenhXTEFMSmF1THAzSndqNm1xSVJPanlocG9tR2svWUVXSDZKaW1HbDQ2YWRoSy9sCg==",
      "endpoints": [
        "https://github.com/ks98/VoiceTypeX/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
