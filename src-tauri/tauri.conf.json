{
  "$schema": "https://schema.tauri.app/config/2.0.0-rc",
  "productName": "VoiceTypeX",
  "version": "0.1.0",
  "identifier": "de.kevin-stenzel.voicetypex",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceTypeX",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Diktiere — VoiceTypeX schreibt es.",
    "longDescription": "VoiceTypeX ist ein Diktier-Tool, das Audio per Hotkey aufnimmt, lokal oder via Cloud transkribiert und den Text an der aktuellen Cursor-Position einfuegt. Konfigurierbare Modi steuern Transkription, LLM-Nachbearbeitung und Einfuege-Methode. BYOK-Cloud (xAI, OpenAI, Anthropic, Groq, Deepgram); lokal via whisper.cpp und Ollama.",
    "resources": ["../assets/cue_start.wav", "../assets/cue_stop.wav"],
    "linux": {
      "deb": {
        "depends": [
          "libopenblas0",
          "libasound2",
          "libxdo3"
        ]
      }
    }
  }
}
